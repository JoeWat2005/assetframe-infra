# Copy to .env.local for local dev, and set the same in Vercel for production.
# NEXT_PUBLIC_* are exposed to the browser (safe). Everything else is server-only.

# --- Site (public) ---
NEXT_PUBLIC_SITE_URL=https://www.assetframe.co.uk
NEXT_PUBLIC_PRO_PRICE=$19.99/month        # display label (USD); must match the Clerk Billing 'pro' plan price
NEXT_PUBLIC_ANALYTICS_URL=                # your Vercel project Analytics tab (admin links); optional
NEXT_PUBLIC_GA_ID=                        # Google Analytics 4 Measurement ID (G-XXXXXXX); enables GA + the cookie banner
NEXT_PUBLIC_GA_URL=                       # optional; your GA dashboard link for the admin page

# --- Database (Neon Postgres; pooled connection string) ---
DATABASE_URL=
# Optional: Neon `development` branch (used by preview deploys). When set, `npm run sync-db`
# updates BOTH this and DATABASE_URL on every publish, so prod + preview stay in lockstep.
DATABASE_URL_DEV=

# --- Clerk auth + billing (clerk.com -> API keys) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=                     # Clerk Dashboard -> Webhooks -> signing secret (verifies user.deleted AND billing subscription.* / subscriptionItem.* events)

# --- Admin (comma-separated emails get the admin dashboard before you set roles in Clerk) ---
ADMIN_EMAILS=you@example.com

# --- Cloudflare R2 (private Pro files) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=assetframe-pro

# --- Web push (browser notifications; generate with: npx web-push generate-vapid-keys) ---
VAPID_PUBLIC_KEY=                         # VAPID public key
VAPID_PRIVATE_KEY=                        # VAPID private key (server-only secret)
VAPID_SUBJECT=mailto:contact@assetframe.co.uk   # contact URI the push service can reach you at
NEXT_PUBLIC_VAPID_PUBLIC_KEY=             # SAME value as VAPID_PUBLIC_KEY (browser needs it to subscribe)

# --- Cron (daily new-editions alert job; the route fails closed without this) ---
CRON_SECRET=                              # any long random string; Vercel Cron sends it as `Authorization: Bearer`

# --- Email (Resend; alerts/newsletter — fallback for users without web push) ---
RESEND_API_KEY=                           # resend.com -> API Keys
RESEND_FROM=AssetFrame <alerts@assetframe.co.uk>   # sender local-part is free; domain must be Resend-verified

# --- Google Places (the /reviews page; OPTIONAL — needs a Google Business Profile) ---
GOOGLE_MAPS_API_KEY=                      # Google Cloud -> enable Places API (New)
GOOGLE_PLACE_ID=                          # your Business Profile place id (Place ID Finder)

# --- Rate limiting + engine link (Upstash Redis; recommended) ---
# Backs per-API-key / per-IP rate limits AND the engine wake/heartbeat keys shared with the box.
# WITHOUT these, rate limiting FAILS OPEN (no limiting applied) and the engine-control wake no-ops.
# Accepts any ONE of three naming schemes (first found wins): the canonical @upstash/redis names
# below, the Vercel<->Upstash Marketplace names (UPSTASH_KV_REST_API_URL/_TOKEN), or the generic
# Vercel KV names (KV_REST_API_URL/_TOKEN).
UPSTASH_REDIS_REST_URL=                   # e.g. https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=                 # Upstash REST token (server-only secret)
UPSTASH_KEY_PREFIX=                       # OPTIONAL; namespaces keys when one Redis backs >1 env (MUST match the engine)

# --- Market data (OPTIONAL) ---
COINGECKO_API_KEY=                        # OPTIONAL; enables the CoinGecko crypto fallback for /api/v1/data/* (the keyless tier works without it)

# --- Box control plane (HTTP cutover; OPTIONAL — unset = box commands go via the Neon queue) ---
# When ALL FOUR are set, allow-listed box commands POST to the box control server over the Cloudflare
# Tunnel (instant) instead of the ~30s Neon poll; restart_poller/pull_latest always stay on the Neon
# path. A box failure falls back to the Neon queue, so this is safe to enable incrementally.
ASSETFRAME_CONTROL_URL=                    # e.g. https://engine.assetframe.co.uk (the tunnel hostname)
ASSETFRAME_CONTROL_TOKEN=                  # the box app bearer (= ASSETFRAME_CONTROL_TOKEN on the box) — SECRET
CF_ACCESS_CLIENT_ID=                       # Cloudflare Access service-token client id
CF_ACCESS_CLIENT_SECRET=                   # Cloudflare Access service-token secret — SECRET (rotate the leaked pair)
