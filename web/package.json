{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "overrides": {
    "postcss": "^8.5.10"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "migrate": "node-pg-migrate --envPath .env.local",
    "migrate:up": "node-pg-migrate up --envPath .env.local",
    "migrate:down": "node-pg-migrate down --envPath .env.local",
    "migrate:create": "node-pg-migrate create --migration-file-language js",
    "sync-db": "node scripts/sync-db.mjs",
    "db:setup": "npm run migrate:up && npm run sync-db"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1068.0",
    "@aws-sdk/s3-request-presigner": "^3.1068.0",
    "@clerk/nextjs": "^7.5.2",
    "@neondatabase/serverless": "^1.1.0",
    "@next/third-parties": "^16.2.9",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "radix-ui": "^1.5.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.0",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.21.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
