__pycache__/
*.pyc

# Working market data — regenerated every run
data/candles/*
!data/candles/.gitkeep
data/analysis/*
!data/analysis/.gitkeep
data/payloads/*
!data/payloads/.gitkeep

# Registered predictions are per-machine working state; the scored results land
# in the tracked ledger. Delete these two lines to version pending predictions.
data/predictions/*
!data/predictions/.gitkeep

# Generated report output — delete these two lines if you want published reports versioned
reports/*
!reports/.gitkeep

# V2 working artifacts — per-run inputs (research/social packs, ledger context, briefs) and
# distribution drafts. Like data/payloads, these are working state, not versioned.
data/briefs/*
data/research/*
data/social/*
data/ledger_context/*
data/social_posts/*

# Derived ledger products — rebuilt by calibrate.py / research_memory.py.
# The source-of-truth outcome_ledger.csv stays tracked.
ledger/calibration_map.json
ledger/research_memory.json

# Generated static site — rebuilt by scripts/build_site.py (deploy by running the build, not committing it)
site/

# Secrets — never commit, anywhere (belt-and-suspenders; web/.gitignore also covers this)
**/.env
**/.env.local
**/.env.*.local

# Node / Next build artifacts (the web app also has its own .gitignore)
**/node_modules/
web/.next/
web/out/

.vercel
.env*
